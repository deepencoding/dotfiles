# ~/.ssh/config
# The CONFIG is tracked. Keys are NEVER in the repo.

# Machine-specific hosts live out of repo, same pattern as secrets:
Include ~/.ssh/config.local

Host *
    # UseKeychain is macOS-only; IgnoreUnknown makes Linux skip it silently
    IgnoreUnknown UseKeychain
    UseKeychain yes
    AddKeysToAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

# Example host entry (put real ones in ~/.ssh/config.local):
# Host myserver
#     HostName 203.0.113.10
#     User deep
#     IdentityFile ~/.ssh/id_ed25519
